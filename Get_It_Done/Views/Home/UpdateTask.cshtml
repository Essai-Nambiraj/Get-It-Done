@model Get_It_Done.Models.TaskItem

<h2>Edit Task</h2>

<form asp-action="UpdateTask" method="post">
    <input type="hidden" asp-for="TaskId" />

    <div>
        <label>Task</label>
        <input asp-for="Task" />
    </div>

    <div>
        <label>Priority</label>
        <input type="checkbox" asp-for="IsPriority"/>
    </div>

    <div>
        <label>Deadline</label>
        <input type="date" asp-for="DeadLine" />
    </div>

    <button type="submit">Save</button>
</form>